// Jenkinsfile — pipeline CI/CD city
// Hypothèses :
//   - Jenkins LTS avec agents Linux ayant Docker, Maven, Node 24, kubectl, kustomize.
//   - JDK 21 (Temurin) installé via "Manage Jenkins → Tools → JDK" sous le nom 'jdk-21'.
//   - Credentials configurées (id Jenkins) :
//       ghcr-pat            : Personal Access Token GitHub (write:packages)
//       gpg-signing-key     : clé GPG pour signer les tags
//       k8s-prod            : kubeconfig du cluster prod
//       sonar-token         : token Sonar (Secret text) — facultatif si RUN_SONAR=true
//       city-app-secrets    : Secret text(s) — JWT_SECRET, DB_USERNAME, DB_PASSWORD,
//                             MAIL_PASSWORD (injectés pour les tests d'intégration depuis
//                             Tour 38 : plus de defaults dans application.yml).
//   - Webhook git → Jenkins sur push tag v*
//
// Étapes :
//   checkout → audit → tests → (sonar optionnel) → build → push → deploy staging
//   → manual gate → deploy prod → smoke

pipeline {
  agent {
    label 'docker && linux'
  }

  options {
    timestamps()
    timeout(time: 30, unit: 'MINUTES')
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '20'))
  }

  parameters {
    booleanParam(
      name: 'RUN_SONAR',
      defaultValue: false,
      description: 'Lance l’analyse SonarQube après les tests (sinon stage skipped).'
    )
    string(
      name: 'DOCKER_REGISTRY',
      defaultValue: 'ghcr.io',
      description: 'Registry Docker cible (ghcr.io, docker.io/<org>, etc.).'
    )
    string(
      name: 'REGISTRY_OWNER',
      defaultValue: 'your-org',
      description: 'Org/namespace pour les images (sera concaténé : <REGISTRY>/<OWNER>/city-*).'
    )
  }

  tools {
    // Nécessite JDK 21 enregistré dans "Manage Jenkins → Tools" sous l'id 'jdk-21'.
    jdk 'jdk-21'
  }

  environment {
    REGISTRY    = "${params.DOCKER_REGISTRY}"
    REGISTRY_OWNER = "${params.REGISTRY_OWNER}"
    BACK_IMG    = "${REGISTRY}/${REGISTRY_OWNER}/city-backend"
    FRONT_IMG   = "${REGISTRY}/${REGISTRY_OWNER}/city-frontend"
    TZ          = 'Africa/Nouakchott'
    // Sécurité : ces vars sont remplacées par withCredentials dans la stage Tests,
    // mais on initialise pour éviter NPE dans des steps script éventuels.
    JAVA_HOME   = "${tool 'jdk-21'}"
    PATH        = "${env.JAVA_HOME}/bin:${env.PATH}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
        script {
          env.GIT_TAG    = sh(returnStdout: true, script: 'git describe --tags --always').trim()
          env.GIT_SHA    = sh(returnStdout: true, script: 'git rev-parse --short HEAD').trim()
          env.IS_TAG     = sh(returnStdout: true, script: 'git describe --exact-match --tags HEAD 2>/dev/null || echo "NO"').trim() != "NO" ? "true" : "false"
          env.APP_TAG    = env.IS_TAG == "true" ? env.GIT_TAG : "edge-${env.GIT_SHA}"
          echo "Building APP_TAG=${env.APP_TAG} (IS_TAG=${env.IS_TAG})"
        }
        sh 'java -version'
        sh 'cd citybackend && ./mvnw -v'
      }
    }

    stage('Audit & Lint') {
      parallel {
        stage('Backend audit') {
          steps {
            dir('citybackend') {
              sh './mvnw -B -ntp -DskipTests verify -Dmaven.test.skip=false test-compile'
            }
          }
        }
        stage('Frontend lint') {
          steps {
            dir('cityfrontend') {
              sh 'npm ci --no-audit --no-fund'
              sh 'npm run lint || true'    // non bloquant en V1
            }
          }
        }
      }
    }

    stage('Tests') {
      parallel {
        stage('Backend tests') {
          steps {
            // Tour 38 : application.yml ne fournit plus de defaults pour ces secrets.
            // On injecte des credentials Jenkins (Secret text) pour que les tests
            // d'intégration (147 unit + 62 IT) démarrent correctement.
            withCredentials([
              string(credentialsId: 'city-jwt-secret',  variable: 'JWT_SECRET'),
              string(credentialsId: 'city-db-username', variable: 'DB_USERNAME'),
              string(credentialsId: 'city-db-password', variable: 'DB_PASSWORD'),
              string(credentialsId: 'city-mail-password', variable: 'MAIL_PASSWORD')
            ]) {
              dir('citybackend') {
                sh './mvnw -B -ntp verify'
              }
            }
          }
          post {
            always {
              // Capture Surefire (unit tests *Test/*Tests) ET Failsafe (IT *IT)
              junit allowEmptyResults: true,
                    testResults: 'citybackend/target/surefire-reports/*.xml,citybackend/target/failsafe-reports/*.xml'
            }
          }
        }
        stage('Frontend tests') {
          steps {
            dir('cityfrontend') {
              // Karma + Jasmine (palier 1 — voir CLAUDE.md §3 Frontend).
              // Non bloquant tant que la base de tests n'a pas atteint la maturité requise.
              sh 'npx ng test --watch=false --browsers=ChromeHeadless --code-coverage || true'
            }
          }
        }
      }
    }

    stage('Sonar') {
      // Optionnel : déclenché manuellement via le paramètre RUN_SONAR (build with parameters).
      // Activer aussi automatiquement sur la branche main en décommentant la ligne ci-dessous.
      when {
        expression { return params.RUN_SONAR }
        // anyOf { branch 'main' ; expression { return params.RUN_SONAR } }
      }
      steps {
        withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
          dir('citybackend') {
            sh '''
              ./mvnw -B -ntp sonar:sonar \
                -Dsonar.host.url=${SONAR_URL:-https://sonar.example.mr} \
                -Dsonar.token=${SONAR_TOKEN} \
                -Dsonar.projectKey=city-backend
            '''
          }
        }
      }
    }

    stage('Build & Push images') {
      when { anyOf { branch 'main' ; expression { env.IS_TAG == "true" } } }
      parallel {
        stage('Backend image') {
          steps {
            withCredentials([usernamePassword(
                  credentialsId: 'ghcr-pat',
                  usernameVariable: 'GHCR_USER',
                  passwordVariable: 'GHCR_TOKEN')]) {
              dir('citybackend') {
                sh '''
                  set -e
                  ./mvnw -B -ntp -DskipTests \
                    -Djib.to.image=${BACK_IMG}:${APP_TAG} \
                    -Djib.to.auth.username=$GHCR_USER \
                    -Djib.to.auth.password=$GHCR_TOKEN \
                    -Djib.from.image=eclipse-temurin:21.0.5_11-jre-noble \
                    -Djib.container.jvmFlags="-XX:MaxRAMPercentage=75,-XX:+UseG1GC,-Duser.timezone=Africa/Nouakchott" \
                    -Djib.container.environment=SPRING_PROFILES_ACTIVE=prod \
                    -Djib.container.ports=8080 \
                    -Djib.container.user=10001 \
                    com.google.cloud.tools:jib-maven-plugin:3.4.4:build
                '''
              }
            }
          }
        }
        stage('Frontend image') {
          steps {
            withCredentials([usernamePassword(
                  credentialsId: 'ghcr-pat',
                  usernameVariable: 'GHCR_USER',
                  passwordVariable: 'GHCR_TOKEN')]) {
              sh '''
                echo "$GHCR_TOKEN" | docker login ghcr.io -u "$GHCR_USER" --password-stdin
                docker build \
                  -f deploiement/ressources/docker/Dockerfile.frontend \
                  --build-arg API_BASE=/citybackend \
                  -t ${FRONT_IMG}:${APP_TAG} \
                  cityfrontend/
                docker push ${FRONT_IMG}:${APP_TAG}
                docker logout ghcr.io
              '''
            }
          }
        }
      }
    }

    stage('Deploy staging') {
      when { branch 'main' }
      steps {
        echo "Déploiement automatique en staging non implémenté en V1 (placeholder)."
        // Exemple : kubectl --kubeconfig $K8S_STAGING set image deploy/city-backend backend=${BACK_IMG}:${APP_TAG}
      }
    }

    stage('Approval prod') {
      when { expression { env.IS_TAG == "true" } }
      options { timeout(time: 4, unit: 'HOURS') }
      steps {
        input message: "Déployer ${APP_TAG} en PRODUCTION ?",
              ok: "Oui, je suis sûr",
              submitter: "tech-lead,ops-lead"
      }
    }

    stage('Deploy prod') {
      when { expression { env.IS_TAG == "true" } }
      steps {
        withCredentials([file(credentialsId: 'k8s-prod', variable: 'KUBECONFIG_FILE')]) {
          sh '''
            export KUBECONFIG=$KUBECONFIG_FILE
            cd deploiement/ressources/k8s/
            kustomize edit set image \
              ghcr.io/REPLACE_ORG/city-backend=${BACK_IMG}:${APP_TAG} \
              ghcr.io/REPLACE_ORG/city-frontend=${FRONT_IMG}:${APP_TAG}
            kustomize build . | kubectl apply -f -
            kubectl -n city rollout status deploy/city-backend  --timeout=10m
            kubectl -n city rollout status deploy/city-frontend --timeout=5m
          '''
        }
      }
    }

    stage('Smoke test prod') {
      when { expression { env.IS_TAG == "true" } }
      steps {
        sh '''
          curl -fsS https://city.example.mr/citybackend/actuator/health | jq -e '.status == "UP"'
          curl -fsS https://city.example.mr/ | grep -i '<title>'
        '''
      }
    }
  }

  post {
    success {
      echo "✓ Pipeline OK — ${APP_TAG}"
      // Notifier Slack/Teams si configuré
    }
    failure {
      echo "✗ Pipeline échec — voir logs"
      // Notifier ops avec le numéro de build
    }
    always {
      cleanWs()
    }
  }
}
