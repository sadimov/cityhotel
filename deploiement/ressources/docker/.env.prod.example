# Template de variables d'environnement pour docker-compose.prod.yml
# Renommer en .env, compléter, chmod 600.
# NE PAS COMMITER ce fichier une fois rempli.

# ---- Domaine et certificats ----
DOMAIN=city.example.mr
ACME_EMAIL=ops@city.example.mr

# ---- Versions ----
# Tag git de release = tag image. Ne JAMAIS utiliser 'latest' en prod.
APP_TAG=1.0.0
REGISTRY_OWNER=your-org

# ---- Postgres ----
POSTGRES_DB=cityprojectdb
POSTGRES_USER=cityapp
# Génération recommandée : pwgen -ynsBv 32 1
POSTGRES_PASSWORD=CHANGE_ME_RANDOM_32_CHARS

# ---- Backend ----
# Génération : openssl rand -base64 48
JWT_SECRET=CHANGE_ME_RANDOM_BASE64_64_CHARS

# ---- Mail (optionnel — laisser vide si pas configuré) ----
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
