# /!\ NE PAS COMMITER CE FICHIER UNE FOIS RENSEIGNÉ /!\
# Renommer en secret-postgres.yaml et SCELLER avec sealed-secrets ou SOPS.
#
# Génération :
#   POSTGRES_PASSWORD=$(pwgen -ynsBv 32 1)
#
# Application directe (sans sealed-secrets) — pour staging uniquement :
#   kubectl create secret generic city-postgres-secret -n city \
#     --from-literal=POSTGRES_DB=cityprojectdb \
#     --from-literal=POSTGRES_USER=cityapp \
#     --from-literal=POSTGRES_PASSWORD="$POSTGRES_PASSWORD"

apiVersion: v1
kind: Secret
metadata:
  name: city-postgres-secret
  namespace: city
type: Opaque
stringData:
  POSTGRES_DB: "cityprojectdb"
  POSTGRES_USER: "cityapp"
  POSTGRES_PASSWORD: "REPLACE_WITH_RANDOM_32_CHAR"
