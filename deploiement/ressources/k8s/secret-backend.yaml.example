# /!\ NE PAS COMMITER CE FICHIER UNE FOIS RENSEIGNÉ /!\
# Renommer en secret-backend.yaml et SCELLER avec sealed-secrets ou SOPS.
#
# Génération :
#   JWT_SECRET=$(openssl rand -base64 48)
#   DB_PASSWORD doit être identique à POSTGRES_PASSWORD du secret-postgres.

apiVersion: v1
kind: Secret
metadata:
  name: city-backend-secret
  namespace: city
type: Opaque
stringData:
  DB_USERNAME: "cityapp"
  DB_PASSWORD: "REPLACE_WITH_SAME_AS_POSTGRES_PASSWORD"
  JWT_SECRET: "REPLACE_WITH_OPENSSL_RAND_BASE64_48"
  MAIL_USERNAME: "no-reply@city.example.mr"
  MAIL_PASSWORD: "REPLACE_WITH_SMTP_PASSWORD"
