  "env": {
    "PROJECT_NAME": "city-hotel",
    "BACKEND_DIR": "citybackend",
    "FRONTEND_DIR": "cityfrontend",
    "DB_NAME": "cityprojectdb",
    "DB_USER": "postgres"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -Eq 'rm -rf|drop database|truncate|git push --force|git push -f|git reset --hard|git update-ref|git symbolic-ref|delete from .* where 1|drop table'; then echo 'Commande dangereuse bloquée par hook' >&2; exit 2; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=\"$CLAUDE_TOOL_PATH\"; if [[ \"$FILE\" == *.java ]]; then echo \"[hook] Java édité: $FILE — penser à vérifier hotelId, @PreAuthorize, DTO\"; fi; if [[ \"$FILE\" == *.ts ]]; then echo \"[hook] TS édité: $FILE — penser à takeUntil, i18n, guards\"; fi"
          }
        ]
      }
    ]
  },
  "model": "claude-opus-4-7"
}
