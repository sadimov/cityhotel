<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Bloc B1 (compta native) - Plan Comptable General SYSCOHADA mauritanien.

  Reference globale partagee entre tous les hotels (pas de hotel_id, pas
  d'isolation tenant Hibernate). Lecture seule cote application : les
  evolutions du PCG passent par de nouveaux changesets Liquibase.

  Source : plan_comptable_mauritanien.pdf (racine projet) + SYSCOHADA AUDCIF.

  Comptes seedes :
    - Classe 1 : Ressources durables (capitaux, reserves, resultat, provisions)
    - Classe 2 : Actif immobilise (terrains, batiments, mobilier, amortissements)
    - Classe 3 : Stocks (marchandises, matieres premieres restaurant, consommables)
    - Classe 4 : Tiers (fournisseurs, clients, personnel, etat, TVA)
    - Classe 5 : Tresorerie (banque, caisses physiques, wallets mobile money)
    - Classe 6 : Charges (achats, services exterieurs, personnel, amortissements)
    - Classe 7 : Produits (ventes hotelieres, reductions, exceptionnels)

  Les comptes utilisable=false sont des comptes de regroupement (titres) -
  jamais references par une ecriture, sert au regroupement balance/bilan.
  ============================================================================
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="039-1-create-table-plan-comptable-general" author="cityprojects">
        <comment>
            Table referentielle du Plan Comptable General SYSCOHADA mauritanien.
            PK metier = compte_code (10 chars). Pas de hotel_id (referentiel global).
        </comment>

        <createTable tableName="plan_comptable_general" schemaName="finance">
            <column name="compte_code" type="VARCHAR(10)">
                <constraints primaryKey="true" primaryKeyName="pk_plan_comptable_general" nullable="false"/>
            </column>
            <column name="libelle" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="classe" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="parent_code" type="VARCHAR(10)"/>
            <column name="nature" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="sens_normal" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="utilisable" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            ALTER TABLE finance.plan_comptable_general
            ADD CONSTRAINT chk_plan_comptable_general_classe_range
            CHECK (classe BETWEEN 1 AND 7)
        </sql>

        <sql>
            ALTER TABLE finance.plan_comptable_general
            ADD CONSTRAINT chk_plan_comptable_general_nature
            CHECK (nature IN ('ACTIF', 'PASSIF', 'CHARGE', 'PRODUIT', 'MIXTE'))
        </sql>

        <sql>
            ALTER TABLE finance.plan_comptable_general
            ADD CONSTRAINT chk_plan_comptable_general_sens
            CHECK (sens_normal IN ('DEBITEUR', 'CREDITEUR', 'MIXTE'))
        </sql>

        <sql>
            ALTER TABLE finance.plan_comptable_general
            ADD CONSTRAINT chk_plan_comptable_general_statut
            CHECK (statut IN ('ACTIF', 'ARCHIVE'))
        </sql>

        <createIndex tableName="plan_comptable_general" schemaName="finance"
                     indexName="ix_pcg_classe">
            <column name="classe"/>
            <column name="compte_code"/>
        </createIndex>

        <createIndex tableName="plan_comptable_general" schemaName="finance"
                     indexName="ix_pcg_parent">
            <column name="parent_code"/>
        </createIndex>

        <rollback>
            <dropTable tableName="plan_comptable_general" schemaName="finance"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Seed PCG mauritanien (SYSCOHADA).
         Une seule transaction pour idempotence (preCondition sur table vide).
         ==================================================================== -->
    <changeSet id="039-2-seed-plan-comptable-general" author="cityprojects">
        <preConditions onFail="MARK_RAN">
