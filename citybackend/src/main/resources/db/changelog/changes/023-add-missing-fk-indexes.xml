<!--
  ============================================================================
  Tour 7D (audit /db-validate) - Index manquants sur FK secondaires.

  Constat de l'audit :
  - 13 colonnes referencant une FK n'ont pas d'index dedie. PostgreSQL ne
    cree PAS automatiquement d'index sur les colonnes FK enfant -> impact
    perfo reel sur :
      * DELETE / UPDATE de la table parent (full scan enfant pour CASCADE
        / SET NULL).
      * JOIN frequents (controleurs admin, reporting Vague 3).
  - Les index hotel_id principaux sont deja poses sur les tables maitres
    (003 / 005 / 006 / 007 / 008). C'est le 2e niveau (FK satellites) qui
    manque.

  Strategie : un changeSet ADDITIF par index (atomicite max), avec
  preCondition MARK_RAN sur indexExists pour absorber les cas ou un index
  homonyme aurait ete cree manuellement (ex. EXPLAIN ANALYZE + CREATE INDEX
  CONCURRENTLY en prod).

  Convention de nommage : ix_<table_court>_<colonne_court>. Coherent avec les
  index existants dans 003 / 005 / 006.
  ============================================================================
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ============================================================
         023-1 : hebergement.reservations.user_id
         ============================================================ -->
    <changeSet id="023-1-ix-reservations-user" author="cityteam">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists schemaName="hebergement" indexName="ix_reservations_user"/>
            </not>
        </preConditions>
        <comment>Index FK reservations.user_id (createur reservation).</comment>

        <createIndex tableName="reservations" schemaName="hebergement" indexName="ix_reservations_user">
            <column name="user_id"/>
        </createIndex>

        <rollback>
            <dropIndex tableName="reservations" schemaName="hebergement" indexName="ix_reservations_user"/>
        </rollback>
    </changeSet>

