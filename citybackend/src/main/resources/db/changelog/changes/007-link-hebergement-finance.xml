<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Tour 19 - Link tables hebergement -> finance.

  Closes les TODO[tour-finance] poses au Tour 11 :
  - Reservation.facture_id (entite Reservation, ligne 42)
  - Nuitee.facture_id + Nuitee.ligne_facture_id (entite Nuitee, ligne 27)
  - StatutNuitee.FACTUREE est deja present, pas de schema change.

  Strategie : changeset additif (ALTER TABLE ADD COLUMN + FK), JAMAIS modifier
  003-create-hebergement-schema.xml deja applique.

  Les colonnes sont nullable : une reservation existante n'a pas encore de
  facture (relation 1:1 differee : on facture apres consommation des nuitees).

  ON DELETE SET NULL : si une facture est purgee (soft-delete strict + clean-up
  archive), les reservations/nuitees ne sont pas detruites. Pas de cascade.
  ============================================================================
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="007-1-add-facture-id-reservations" author="cityprojects">
        <comment>
            Ajoute reservations.facture_id (FK vers finance.factures, nullable).
            Cloture TODO[tour-finance] de Reservation.java ligne 42.
            Une reservation peut etre liee a au plus une facture client unique
            (1:1) - cf. FactureService.fromReservation().
        </comment>
        <addColumn tableName="reservations" schemaName="hebergement">
            <column name="facture_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
            baseTableName="reservations" baseTableSchemaName="hebergement"
            baseColumnNames="facture_id"
            referencedTableName="factures" referencedTableSchemaName="finance"
            referencedColumnNames="facture_id"
            constraintName="fk_reservations_facture"
            onDelete="SET NULL"/>

        <createIndex tableName="reservations" schemaName="hebergement" indexName="ix_reservations_facture">
            <column name="facture_id"/>
        </createIndex>

        <rollback>
            <dropForeignKeyConstraint
                baseTableName="reservations" baseTableSchemaName="hebergement"
                constraintName="fk_reservations_facture"/>
            <dropColumn tableName="reservations" schemaName="hebergement" columnName="facture_id"/>
        </rollback>
    </changeSet>

    <changeSet id="007-2-add-facture-id-nuitees" author="cityprojects">
        <comment>
            Ajoute nuitees.facture_id et nuitees.ligne_facture_id (FK nullable).
            Cloture TODO[tour-finance] de Nuitee.java ligne 27 et StatutNuitee.java
            ligne 11. Une nuitee CONSOMMEE devient FACTUREE quand elle est rattachee
            a une LigneFacture (cf. FactureService.fromReservation()).
        </comment>
        <addColumn tableName="nuitees" schemaName="hebergement">
            <column name="facture_id" type="BIGINT"/>
        </addColumn>
        <addColumn tableName="nuitees" schemaName="hebergement">
            <column name="ligne_facture_id" type="BIGINT"/>
        </addColumn>

        <addForeignKeyConstraint
            baseTableName="nuitees" baseTableSchemaName="hebergement"
            baseColumnNames="facture_id"
            referencedTableName="factures" referencedTableSchemaName="finance"
            referencedColumnNames="facture_id"
            constraintName="fk_nuitees_facture"
            onDelete="SET NULL"/>

        <addForeignKeyConstraint
            baseTableName="nuitees" baseTableSchemaName="hebergement"
            baseColumnNames="ligne_facture_id"
            referencedTableName="lignes_factures" referencedTableSchemaName="finance"
            referencedColumnNames="ligne_facture_id"
            constraintName="fk_nuitees_ligne_facture"
            onDelete="SET NULL"/>

        <createIndex tableName="nuitees" schemaName="hebergement" indexName="ix_nuitees_facture">
            <column name="facture_id"/>
        </createIndex>

        <rollback>
            <dropForeignKeyConstraint
                baseTableName="nuitees" baseTableSchemaName="hebergement"
                constraintName="fk_nuitees_ligne_facture"/>
            <dropForeignKeyConstraint
                baseTableName="nuitees" baseTableSchemaName="hebergement"
                constraintName="fk_nuitees_facture"/>
            <dropColumn tableName="nuitees" schemaName="hebergement" columnName="ligne_facture_id"/>
            <dropColumn tableName="nuitees" schemaName="hebergement" columnName="facture_id"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
