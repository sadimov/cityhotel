<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Bloc B4 (compta native - TVA hoteliere mauritanienne) - declarations TVA
  par hotel + periode.

  Periodicite standard mauritanienne : mensuelle (le 15 du mois suivant).
  Le service applicatif ne contraint pas la longueur de la periode :
  un admin peut produire une declaration ponctuelle (semaine, trimestre).

  Cycle de vie : BROUILLON -> VALIDEE. La validation genere atomiquement
  l'ecriture de liquidation (journal OD) :
    DEBIT  445700 (TVA collectee)
    CREDIT 445600 (TVA deductible)
    CREDIT 445800 (TVA a decaisser - solde positif)
      ou
    DEBIT  445800 (credit reportable - solde negatif)

  Unicite (hotel_id, date_debut, date_fin) garantit l'idempotence du
  POST de calcul (cf. DeclarationTvaServiceImpl.calculer).
  ============================================================================
-->
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="054-1-create-table-declaration-tva" author="cityprojects">
        <comment>
            Declaration TVA par hotel et periode. Tenant-aware (CHECK
            hotel_id > 0). FK optionnelle vers exercice (rattachement
            informatif - une declaration peut couvrir plusieurs exercices
            theoriquement, mais en pratique c'est mensuel).
        </comment>

        <createTable tableName="declaration_tva" schemaName="finance">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_declaration_tva" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="date_debut" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="date_fin" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="total_tva_collectee" type="DECIMAL(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="total_tva_deductible" type="DECIMAL(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="total_tva_a_decaisser" type="DECIMAL(19,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="BROUILLON">
                <constraints nullable="false"/>
            </column>
            <column name="exercice_id" type="BIGINT"/>
            <column name="ecriture_liquidation_id" type="BIGINT"/>
            <column name="date_validation" type="DATE"/>
            <column name="validee_par" type="VARCHAR(100)"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="declaration_tva" baseTableSchemaName="finance"
                baseColumnNames="hotel_id"
                referencedTableName="hotels" referencedTableSchemaName="core"
                referencedColumnNames="hotel_id"
                constraintName="fk_declaration_tva_hotel"/>

        <addForeignKeyConstraint
                baseTableName="declaration_tva" baseTableSchemaName="finance"
                baseColumnNames="exercice_id"
                referencedTableName="exercice" referencedTableSchemaName="finance"
                referencedColumnNames="id"
                constraintName="fk_declaration_tva_exercice"
                onDelete="SET NULL"/>

        <addForeignKeyConstraint
                baseTableName="declaration_tva" baseTableSchemaName="finance"
                baseColumnNames="ecriture_liquidation_id"
                referencedTableName="ecriture_comptable" referencedTableSchemaName="finance"
                referencedColumnNames="id"
                constraintName="fk_declaration_tva_ecriture"
                onDelete="SET NULL"/>

        <addUniqueConstraint
                tableName="declaration_tva" schemaName="finance"
                columnNames="hotel_id, date_debut, date_fin"
                constraintName="uk_declaration_tva_hotel_periode"/>

        <sql>
            ALTER TABLE finance.declaration_tva
            ADD CONSTRAINT chk_declaration_tva_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <sql>
            ALTER TABLE finance.declaration_tva
            ADD CONSTRAINT chk_declaration_tva_statut
            CHECK (statut IN ('BROUILLON', 'VALIDEE'))
        </sql>

        <sql>
            ALTER TABLE finance.declaration_tva
            ADD CONSTRAINT chk_declaration_tva_periode CHECK (date_debut &lt;= date_fin)
        </sql>

        <createIndex tableName="declaration_tva" schemaName="finance"
                     indexName="ix_declaration_tva_hotel_statut">
            <column name="hotel_id"/>
            <column name="statut"/>
        </createIndex>

        <createIndex tableName="declaration_tva" schemaName="finance"
                     indexName="ix_declaration_tva_hotel_periode">
            <column name="hotel_id"/>
            <column name="date_debut"/>
            <column name="date_fin"/>
        </createIndex>

        <rollback>
            <dropTable tableName="declaration_tva" schemaName="finance"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
