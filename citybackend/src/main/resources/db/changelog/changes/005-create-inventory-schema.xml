            </column>
            <column name="destination" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="BROUILLON">
                <constraints nullable="false"/>
            </column>
            <column name="date_sortie" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="commentaires" type="TEXT"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="bons_sortie" baseTableSchemaName="inventory"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_bons_sortie_hotel"/>

        <addForeignKeyConstraint
            baseTableName="bons_sortie" baseTableSchemaName="inventory"
            baseColumnNames="user_id"
            referencedTableName="dbusers" referencedTableSchemaName="core"
            referencedColumnNames="user_id"
            constraintName="fk_bons_sortie_user"/>

        <addUniqueConstraint
