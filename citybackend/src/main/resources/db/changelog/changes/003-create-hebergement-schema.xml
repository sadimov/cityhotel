        <comment>
            Tarification saisonniere par type de chambre. Permet d'avoir un prix
            different selon la periode (haute saison / basse saison) et le
            week-end.
        </comment>

        <createTable tableName="tarifs_chambres" schemaName="hebergement">
            <column name="tarif_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_tarifs_chambres" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="nom_tarif" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="date_debut" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="date_fin" type="DATE"/>
            <column name="prix_nuit" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="prix_weekend" type="DECIMAL(10,2)"/>
            <column name="actif" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="tarifs_chambres" baseTableSchemaName="hebergement"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_tarifs_chambres_hotel"/>

        <addForeignKeyConstraint
            baseTableName="tarifs_chambres" baseTableSchemaName="hebergement"
            baseColumnNames="type_id"
            referencedTableName="types_chambres" referencedTableSchemaName="hebergement"
            referencedColumnNames="type_id"
            constraintName="fk_tarifs_chambres_type"/>

        <sql>
            ALTER TABLE hebergement.tarifs_chambres
            ADD CONSTRAINT chk_tarifs_chambres_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <createIndex tableName="tarifs_chambres" schemaName="hebergement" indexName="ix_tarifs_hotel_type_periode">
            <column name="hotel_id"/>
            <column name="type_id"/>
            <column name="date_debut"/>
        </createIndex>

        <rollback>
            <dropTable tableName="tarifs_chambres" schemaName="hebergement"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 003-h.5 : table hebergement.reservations
         ==================================================================== -->
    <changeSet id="003-h-5-create-table-reservations" author="cityprojects">
        <comment>
            Reservation d'un sejour : un client principal, un sejour entre
            date_arrivee et date_depart, un statut, un montant total.
            numero_reservation est genere par hotel via NumerotationService
            (type RES) - format RES-{exercice}-{codePays}-{6 chiffres},
            unicite par hotel via uk_reservations_hotel_numero.

            nb_nuits : calcule cote service Java (pas GENERATED Postgres pour
            rester portable H2 en tests).

            FK clients : reference client.clients (deja cree au Tour 8).
            societe_id : nullable, FK vers client.societes (B2B).
            user_id : utilisateur ayant cree la reservation (FK core.dbusers).

            facture_id (TODO[tour-finance]) : non present ici. Le tour finance
            ajoutera la colonne via changeset additif quand factures.factures
            existera.
        </comment>

        <createTable tableName="reservations" schemaName="hebergement">
            <column name="reservation_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_reservations" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="numero_reservation" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="client_principal_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="societe_id" type="BIGINT"/>
            <column name="date_arrivee" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="date_depart" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="nb_nuits" type="INTEGER"/>
            <column name="nb_adultes" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="nb_enfants" type="INTEGER" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="CONFIRMEE">
                <constraints nullable="false"/>
            </column>
            <column name="motif_sejour" type="VARCHAR(100)"/>
            <column name="commentaires" type="TEXT"/>
            <column name="reduction_pourcentage" type="DECIMAL(5,2)" defaultValueNumeric="0"/>
            <column name="montant_total" type="DECIMAL(12,2)" defaultValueNumeric="0"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="reservations" baseTableSchemaName="hebergement"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_reservations_hotel"/>

        <addForeignKeyConstraint
            baseTableName="reservations" baseTableSchemaName="hebergement"
            baseColumnNames="client_principal_id"
            referencedTableName="clients" referencedTableSchemaName="client"
            referencedColumnNames="client_id"
            constraintName="fk_reservations_client_principal"/>

        <addForeignKeyConstraint
            baseTableName="reservations" baseTableSchemaName="hebergement"
            baseColumnNames="societe_id"
            referencedTableName="societes" referencedTableSchemaName="client"
            referencedColumnNames="societe_id"
            constraintName="fk_reservations_societe"
            onDelete="SET NULL"/>

        <addForeignKeyConstraint
            baseTableName="reservations" baseTableSchemaName="hebergement"
            baseColumnNames="user_id"
            referencedTableName="dbusers" referencedTableSchemaName="core"
            referencedColumnNames="user_id"
            constraintName="fk_reservations_user"/>

        <addUniqueConstraint
            tableName="reservations" schemaName="hebergement"
            columnNames="hotel_id, numero_reservation"
            constraintName="uk_reservations_hotel_numero"/>

        <sql>
            ALTER TABLE hebergement.reservations
            ADD CONSTRAINT chk_reservations_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>
        <sql>
            ALTER TABLE hebergement.reservations
            ADD CONSTRAINT chk_reservations_dates CHECK (date_depart &gt; date_arrivee)
        </sql>

        <createIndex tableName="reservations" schemaName="hebergement" indexName="ix_reservations_hotel_dates">
            <column name="hotel_id"/>
            <column name="date_arrivee"/>
            <column name="date_depart"/>
        </createIndex>

        <createIndex tableName="reservations" schemaName="hebergement" indexName="ix_reservations_hotel_statut">
            <column name="hotel_id"/>
            <column name="statut"/>
        </createIndex>

        <createIndex tableName="reservations" schemaName="hebergement" indexName="ix_reservations_client">
            <column name="hotel_id"/>
            <column name="client_principal_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="reservations" schemaName="hebergement"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 003-h.6 : table hebergement.reservations_chambres (N:N)
         ==================================================================== -->
    <changeSet id="003-h-6-create-table-reservations-chambres" author="cityprojects">
        <comment>
            Pivot reservation/chambre : une reservation peut comporter plusieurs
            chambres, eventuellement sur des periodes differentes (sub-segment
            du sejour total). prix_nuit fige le tarif applique au moment de la
            reservation.
        </comment>

        <createTable tableName="reservations_chambres" schemaName="hebergement">
            <column name="reservation_chambre_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_reservations_chambres" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="reservation_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="chambre_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="date_debut" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="date_fin" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="prix_nuit" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="reservations_chambres" baseTableSchemaName="hebergement"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_res_chambres_hotel"/>

        <addForeignKeyConstraint
            baseTableName="reservations_chambres" baseTableSchemaName="hebergement"
            baseColumnNames="reservation_id"
            referencedTableName="reservations" referencedTableSchemaName="hebergement"
            referencedColumnNames="reservation_id"
            constraintName="fk_res_chambres_reservation"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableName="reservations_chambres" baseTableSchemaName="hebergement"
            baseColumnNames="chambre_id"
            referencedTableName="chambres" referencedTableSchemaName="hebergement"
            referencedColumnNames="chambre_id"
            constraintName="fk_res_chambres_chambre"/>

        <addUniqueConstraint
            tableName="reservations_chambres" schemaName="hebergement"
            columnNames="reservation_id, chambre_id, date_debut"
            constraintName="uk_res_chambres"/>

        <sql>
            ALTER TABLE hebergement.reservations_chambres
            ADD CONSTRAINT chk_res_chambres_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <createIndex tableName="reservations_chambres" schemaName="hebergement" indexName="ix_res_chambres_chambre_periode">
            <column name="chambre_id"/>
            <column name="date_debut"/>
            <column name="date_fin"/>
        </createIndex>

        <rollback>
            <dropTable tableName="reservations_chambres" schemaName="hebergement"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 003-h.7 : table hebergement.reservations_clients
         ==================================================================== -->
