        <sql>
            ALTER TABLE hebergement.reservations_clients
            ADD CONSTRAINT chk_res_clients_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <rollback>
            <dropTable tableName="reservations_clients" schemaName="hebergement"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 003-h.8 : table hebergement.nuitees
         ==================================================================== -->
    <changeSet id="003-h-8-create-table-nuitees" author="cityprojects">
        <comment>
            Detail jour-par-jour d'une reservation : 1 ligne = 1 nuit consommee
            par 1 chambre. Permet la facturation au reel et l'audit du night
            audit (ligne marquee CONSOMMEE puis FACTUREE).

            facture_id / ligne_facture_id (TODO[tour-finance]) : non presents
            ici. Le tour finance ajoutera ces colonnes via changeset additif.
        </comment>

        <createTable tableName="nuitees" schemaName="hebergement">
            <column name="nuitee_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_nuitees" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="reservation_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="chambre_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="date_nuit" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="prix_nuit" type="DECIMAL(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="taxe_sejour" type="DECIMAL(10,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="PREVUE">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="nuitees" baseTableSchemaName="hebergement"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_nuitees_hotel"/>

        <addForeignKeyConstraint
            baseTableName="nuitees" baseTableSchemaName="hebergement"
            baseColumnNames="reservation_id"
            referencedTableName="reservations" referencedTableSchemaName="hebergement"
            referencedColumnNames="reservation_id"
            constraintName="fk_nuitees_reservation"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableName="nuitees" baseTableSchemaName="hebergement"
            baseColumnNames="chambre_id"
            referencedTableName="chambres" referencedTableSchemaName="hebergement"
            referencedColumnNames="chambre_id"
            constraintName="fk_nuitees_chambre"/>

        <addUniqueConstraint
            tableName="nuitees" schemaName="hebergement"
            columnNames="reservation_id, chambre_id, date_nuit"
            constraintName="uk_nuitees"/>

        <sql>
            ALTER TABLE hebergement.nuitees
            ADD CONSTRAINT chk_nuitees_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <createIndex tableName="nuitees" schemaName="hebergement" indexName="ix_nuitees_hotel_date">
            <column name="hotel_id"/>
            <column name="date_nuit"/>
        </createIndex>

        <createIndex tableName="nuitees" schemaName="hebergement" indexName="ix_nuitees_reservation_statut">
            <column name="reservation_id"/>
            <column name="statut"/>
        </createIndex>

        <rollback>
            <dropTable tableName="nuitees" schemaName="hebergement"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
