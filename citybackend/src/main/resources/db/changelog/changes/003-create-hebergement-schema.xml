<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Tour 11 - Schema 'hebergement' : types_chambres, chambres, tarifs_chambres,
  reservations, reservations_chambres, reservations_clients, nuitees.

  Source eclatee depuis HEBERGEMENT/entities_services_module_hebergement.java
  (mono - cf. CARTOGRAPHIE_MODULES.md ligne 117) + structures_tables_schema_hebergement.sql
  (spec SQL de reference - cf. ligne 113).

  Conventions appliquees (alignees sur Tour 9bis pour eviter de dupliquer
  l'erreur du module client) :
  - Schema 'hebergement'.
  - PK technique BIGSERIAL (pattern projet, cf. NumerotationSequence).
  - hotel_id BIGINT NOT NULL + FK core.hotels + CHECK > 0 (sentinel ROOT
    interdit comme hotel_id reel, cf. CityTenantIdentifierResolver).
  - created_at, updated_at en TIMESTAMP WITH TIME ZONE (matche Instant JPA,
    UTC neutre - cf. 003-fix-client-schema-alignment.xml).
  - created_by NOT NULL (sentinel "system" cote app, defense en profondeur SQL).
  - updated_by VARCHAR(80) nullable (rest. tour 9bis).
  - Numerotation sequentielle par hotel via NumerotationService :
    UNIQUE (hotel_id, numero_reservation) sur reservations.

  Cross-module reportes au tour finance :
  - Aucune FK vers finance.factures / paiements (le tour finance pourra ajouter
    une colonne facture_id sur reservations / nuitees via changeset additif).

  Le precedent fichier 003-create-hebergement-schema.sql etait VIDE (0 ligne)
  depuis l'origine. Liquibase desactive jusqu'au Tour 5A : aucun changeset
  applique, remplacement sans risque (pas de DATABASECHANGELOG.MD5SUM).

  Specificite Postgres laissee de cote :
  - reservations.nb_nuits GENERATED ALWAYS AS (date_depart - date_arrivee) STORED
    n'est pas portable H2. nb_nuits est calcule cote service (Java) au save et
    persiste comme INTEGER classique pour rester portable.
  - chambres.equipements (JSON Postgres) : remplace par TEXT (serialise JSON
    cote Java). Faisable car peu utilise. Le tour finance/inventory revisitera
    si besoin natif jsonb.
  ============================================================================
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ====================================================================
         Changeset 003-h.1 : creation du schema 'hebergement'
         ==================================================================== -->
    <changeSet id="003-h-1-create-schema" author="cityprojects">
        <comment>Creation du schema SQL 'hebergement' (chambres, reservations, nuitees).</comment>
        <sql>CREATE SCHEMA IF NOT EXISTS hebergement</sql>
        <rollback>
            <sql>DROP SCHEMA IF EXISTS hebergement CASCADE</sql>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 003-h.2 : table hebergement.types_chambres
         ==================================================================== -->
    <changeSet id="003-h-2-create-table-types-chambres" author="cityprojects">
        <comment>
            Catalogue des types de chambres par hotel (Standard, Deluxe, Suite, ...).
            Code unique par hotel.
        </comment>

        <createTable tableName="types_chambres" schemaName="hebergement">
            <column name="type_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_types_chambres" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type_code" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="type_nom" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="superficie" type="DECIMAL(6,2)"/>
            <column name="nb_lits_max" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="nb_personnes_max" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="prix_base" type="DECIMAL(10,2)" defaultValueNumeric="0"/>
            <column name="actif" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="types_chambres" baseTableSchemaName="hebergement"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_types_chambres_hotel"/>

        <addUniqueConstraint
            tableName="types_chambres" schemaName="hebergement"
            columnNames="hotel_id, type_code"
            constraintName="uk_types_chambres_hotel_code"/>

        <sql>
            ALTER TABLE hebergement.types_chambres
            ADD CONSTRAINT chk_types_chambres_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <createIndex tableName="types_chambres" schemaName="hebergement" indexName="ix_types_chambres_hotel_actif">
            <column name="hotel_id"/>
            <column name="actif"/>
        </createIndex>

        <rollback>
            <dropTable tableName="types_chambres" schemaName="hebergement"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 003-h.3 : table hebergement.chambres
         ==================================================================== -->
    <changeSet id="003-h-3-create-table-chambres" author="cityprojects">
        <comment>
            Chambres physiques de l'hotel (1 ligne = 1 chambre identifiee par
            son numero). FK vers types_chambres pour la categorisation.
        </comment>

        <createTable tableName="chambres" schemaName="hebergement">
            <column name="chambre_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_chambres" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="numero_chambre" type="VARCHAR(10)">
                <constraints nullable="false"/>
            </column>
            <column name="type_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="etage" type="INTEGER"/>
            <column name="statut" type="VARCHAR(20)" defaultValue="DISPONIBLE">
                <constraints nullable="false"/>
            </column>
            <column name="nb_lits" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="nb_personnes_max" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <!-- equipements : JSON serialise en TEXT (cf. note d'en-tete) -->
            <column name="equipements" type="TEXT"/>
            <column name="description" type="TEXT"/>
            <column name="actif" type="BOOLEAN" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="chambres" baseTableSchemaName="hebergement"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_chambres_hotel"/>

        <addForeignKeyConstraint
            baseTableName="chambres" baseTableSchemaName="hebergement"
            baseColumnNames="type_id"
            referencedTableName="types_chambres" referencedTableSchemaName="hebergement"
            referencedColumnNames="type_id"
            constraintName="fk_chambres_type"/>

        <addUniqueConstraint
            tableName="chambres" schemaName="hebergement"
            columnNames="hotel_id, numero_chambre"
            constraintName="uk_chambres_hotel_numero"/>

        <sql>
            ALTER TABLE hebergement.chambres
            ADD CONSTRAINT chk_chambres_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <createIndex tableName="chambres" schemaName="hebergement" indexName="ix_chambres_hotel_statut">
            <column name="hotel_id"/>
            <column name="statut"/>
        </createIndex>

        <createIndex tableName="chambres" schemaName="hebergement" indexName="ix_chambres_hotel_type">
            <column name="hotel_id"/>
            <column name="type_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="chambres" schemaName="hebergement"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 003-h.4 : table hebergement.tarifs_chambres
         (gestion saisonniere)
         ==================================================================== -->
