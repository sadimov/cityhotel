<?xml version="1.0" encoding="UTF-8"?>
<!--
  ============================================================================
  Tour 19 - Schema 'finance' : factures, lignes_factures, paiements,
  affectations_paiements, operations_comptes, comptes.

  Source eclatee depuis HEBERGEMENT/files_back/Services_module_finance.java
  (mono - cf. CARTOGRAPHIE_MODULES.md ligne 109) + reference SQL
  FINANCE/files_back/structures_tables_schema_finance.sql.

  Conventions appliquees DIRECTEMENT (patterns Tour 9bis - alignes inventory) :
  - Schema 'finance' (deja cree au Tour 6A pour numerotation_sequence).
  - PK technique BIGSERIAL nommees metier (facture_id, paiement_id, ...).
  - hotel_id BIGINT NOT NULL + FK core.hotels + CHECK > 0 (sentinel ROOT
    interdit comme hotel_id reel, cf. CityTenantIdentifierResolver).
  - created_at, updated_at en TIMESTAMP WITH TIME ZONE (matche Instant JPA, UTC neutre).
  - created_by NOT NULL avec defaultValue="system" (sentinel cote app).
  - updated_by VARCHAR(80) nullable.
  - Numerotation sequentielle par hotel via NumerotationService :
    * UNIQUE (hotel_id, numero_facture) sur factures
    * UNIQUE (hotel_id, numero_paiement) sur paiements
  - user_id (createur) reference core.dbusers via FK.

  Decisions techniques (Tour 19) :
  - PAS de TVA dans la version POS (cf. prompt_restaurant_pos.txt). Champ
    taux_tva conserve sur lignes_factures (DECIMAL 5,2 default 0) pour
    evolution future, mais montants HT et TTC sont egaux dans le cas standard.
  - Avoir : modelise comme Facture avec type_facture = 'AVOIR' + reference
    a la facture originale via facture_reference_id (FK self). Pas de table
    separee.
  - Compte (debit/credit client) : conserve, version simplifiee. Permet le
    journal d'operations comptables. CompteComptable referentiel (plan
    mauritanien) reporte au tour finance-2.
  - ServiceFacturable : reporte au tour finance-2 (pas critique pour facturer
    nuitees + commandes restaurant + bons de sortie). Champ service_id sur
    lignes_factures reste pour evolution.
  - Mutex client/fournisseur sur facture : facture client a reservation_id,
    facture fournisseur a fournisseur_id. CHECK croisé documente mais pas
    impose au niveau SQL pour simplifier (regle service-side).

  Cross-module reportes :
  - Reservation.facture_id : changeset 007-link-hebergement-finance.xml
  - Nuitee.facture_id, Nuitee.ligne_facture_id : idem
  - BonCommande.facture_fournisseur_id : changeset 008-link-inventory-finance.xml
  - LigneFacture.commande_id (restaurant) : pas de FK, reportee au tour restaurant
  - LigneFacture.produit_id : FK posee (inventory.produits existe Tour 16)

  Le precedent fichier 006-create-finance-schema.sql etait VIDE (0 ligne)
  depuis l'origine du projet. Liquibase desactive par defaut : aucun
  changeset applique sur ce fichier, remplacement sans risque (pas de
  DATABASECHANGELOG.MD5SUM en jeu sur les bases existantes).
  ============================================================================
-->
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ====================================================================
         Changeset 006-f.1 : creation du schema 'finance'
         (idempotent : deja cree par 020-create-numerotation-sequence.xml mais
         on garantit la presence pour les bases qui n'auraient pas execute 020)
         ==================================================================== -->
    <changeSet id="006-f-1-create-schema" author="cityprojects">
        <comment>Creation du schema SQL 'finance' (factures, paiements, comptes).</comment>
        <sql>CREATE SCHEMA IF NOT EXISTS finance</sql>
        <rollback>
            <!-- Pas de DROP SCHEMA pour eviter de detruire numerotation_sequence -->
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 006-f.2 : table finance.comptes
         Compte client/societe avec solde et limite de credit. Une seule
         ligne par client/societe par hotel.
         ==================================================================== -->
    <changeSet id="006-f-2-create-table-comptes" author="cityprojects">
        <comment>
            Compte de credit client/societe pour facturation differee. Le solde
            est mis a jour de facon synchrone par OperationCompte (debit a la
            facturation, credit au paiement).
        </comment>

        <createTable tableName="comptes" schemaName="finance">
            <column name="compte_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_comptes" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="numero_compte" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="type_compte" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="client_id" type="BIGINT"/>
            <column name="societe_id" type="BIGINT"/>
            <column name="solde_actuel" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="credit_limite" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="ACTIF">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="comptes" baseTableSchemaName="finance"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_comptes_hotel"/>

        <addForeignKeyConstraint
            baseTableName="comptes" baseTableSchemaName="finance"
            baseColumnNames="client_id"
            referencedTableName="clients" referencedTableSchemaName="client"
            referencedColumnNames="client_id"
            constraintName="fk_comptes_client"/>

        <addForeignKeyConstraint
            baseTableName="comptes" baseTableSchemaName="finance"
            baseColumnNames="societe_id"
            referencedTableName="societes" referencedTableSchemaName="client"
            referencedColumnNames="societe_id"
            constraintName="fk_comptes_societe"/>

        <addUniqueConstraint
            tableName="comptes" schemaName="finance"
            columnNames="hotel_id, numero_compte"
            constraintName="uk_comptes_hotel_numero"/>

        <sql>
            ALTER TABLE finance.comptes
            ADD CONSTRAINT chk_comptes_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <createIndex tableName="comptes" schemaName="finance" indexName="ix_comptes_hotel_client">
            <column name="hotel_id"/>
            <column name="client_id"/>
        </createIndex>

        <createIndex tableName="comptes" schemaName="finance" indexName="ix_comptes_hotel_societe">
            <column name="hotel_id"/>
            <column name="societe_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="comptes" schemaName="finance"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 006-f.3 : table finance.factures
         Facture client (FACT) ou avoir (AVOIR), generee par hotel.
         ==================================================================== -->
    <changeSet id="006-f-3-create-table-factures" author="cityprojects">
        <comment>
            Factures clients et avoirs. numero_facture unique par hotel
            (UNIQUE (hotel_id, numero_facture)) - genere par NumerotationService
            (FACT pour facture, AVOIR pour avoir).
            type_facture differencie facture / avoir / proforma. facture_reference_id
            pointe vers la facture annulee dans le cas d'un avoir.
            reservation_id (si facture client hebergement) et fournisseur_id
            (si facture fournisseur) sont mutuellement exclusifs (regle metier
            cote service, pas CHECK SQL pour souplesse evolution).
        </comment>

        <createTable tableName="factures" schemaName="finance">
            <column name="facture_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_factures" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="numero_facture" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="type_facture" type="VARCHAR(20)" defaultValue="FACTURE">
                <constraints nullable="false"/>
            </column>
            <column name="compte_id" type="BIGINT"/>
            <column name="client_id" type="BIGINT"/>
            <column name="societe_id" type="BIGINT"/>
            <column name="reservation_id" type="BIGINT"/>
            <column name="fournisseur_id" type="BIGINT"/>
            <column name="facture_reference_id" type="BIGINT"/>
            <column name="date_facture" type="DATE" defaultValueComputed="CURRENT_DATE">
                <constraints nullable="false"/>
            </column>
            <column name="date_echeance" type="DATE"/>
            <column name="montant_ht" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="montant_tva" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="montant_ttc" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="montant_paye" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="BROUILLON">
                <constraints nullable="false"/>
            </column>
            <column name="devise" type="VARCHAR(3)" defaultValue="MRU">
                <constraints nullable="false"/>
            </column>
            <column name="commentaires" type="TEXT"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="factures" baseTableSchemaName="finance"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_factures_hotel"/>

        <addForeignKeyConstraint
            baseTableName="factures" baseTableSchemaName="finance"
            baseColumnNames="compte_id"
            referencedTableName="comptes" referencedTableSchemaName="finance"
            referencedColumnNames="compte_id"
            constraintName="fk_factures_compte"/>

        <addForeignKeyConstraint
            baseTableName="factures" baseTableSchemaName="finance"
            baseColumnNames="client_id"
            referencedTableName="clients" referencedTableSchemaName="client"
            referencedColumnNames="client_id"
            constraintName="fk_factures_client"/>

        <addForeignKeyConstraint
            baseTableName="factures" baseTableSchemaName="finance"
            baseColumnNames="societe_id"
            referencedTableName="societes" referencedTableSchemaName="client"
            referencedColumnNames="societe_id"
            constraintName="fk_factures_societe"/>

        <addForeignKeyConstraint
            baseTableName="factures" baseTableSchemaName="finance"
            baseColumnNames="facture_reference_id"
            referencedTableName="factures" referencedTableSchemaName="finance"
            referencedColumnNames="facture_id"
            constraintName="fk_factures_reference"/>

        <addForeignKeyConstraint
            baseTableName="factures" baseTableSchemaName="finance"
            baseColumnNames="user_id"
            referencedTableName="dbusers" referencedTableSchemaName="core"
            referencedColumnNames="user_id"
            constraintName="fk_factures_user"/>

        <addUniqueConstraint
            tableName="factures" schemaName="finance"
            columnNames="hotel_id, numero_facture"
            constraintName="uk_factures_hotel_numero"/>

        <sql>
            ALTER TABLE finance.factures
            ADD CONSTRAINT chk_factures_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <sql>
            ALTER TABLE finance.factures
            ADD CONSTRAINT chk_factures_montants_coherence
            CHECK (montant_paye &gt;= 0 AND montant_paye &lt;= montant_ttc + 0.01)
        </sql>

        <createIndex tableName="factures" schemaName="finance" indexName="ix_factures_hotel_statut">
            <column name="hotel_id"/>
            <column name="statut"/>
        </createIndex>

        <createIndex tableName="factures" schemaName="finance" indexName="ix_factures_hotel_date">
            <column name="hotel_id"/>
            <column name="date_facture"/>
        </createIndex>

        <createIndex tableName="factures" schemaName="finance" indexName="ix_factures_hotel_client">
            <column name="hotel_id"/>
            <column name="client_id"/>
        </createIndex>

        <createIndex tableName="factures" schemaName="finance" indexName="ix_factures_hotel_reservation">
            <column name="hotel_id"/>
            <column name="reservation_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="factures" schemaName="finance"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 006-f.4 : table finance.lignes_factures
         Ligne detaillee d'une facture. Pas de hotel_id sur la ligne :
         l'isolation tenant est portee par la facture parent.
         ==================================================================== -->
    <changeSet id="006-f-4-create-table-lignes-factures" author="cityprojects">
        <comment>
            Lignes detaillees d'une facture. type_ligne distingue NUITEE,
            PRODUIT, COMMANDE (restaurant POS), SERVICE (services hoteliers).
            Une seule des FK metier (nuitee_id, produit_id, commande_id, service_id)
            doit etre renseignee selon le type_ligne (regle metier service-side).
        </comment>

        <createTable tableName="lignes_factures" schemaName="finance">
            <column name="ligne_facture_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_lignes_factures" nullable="false"/>
            </column>
            <column name="facture_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type_ligne" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="nuitee_id" type="BIGINT"/>
            <column name="produit_id" type="BIGINT"/>
            <column name="commande_id" type="BIGINT"/>
            <column name="service_id" type="BIGINT"/>
            <column name="libelle" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="quantite" type="DECIMAL(10,3)" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
            <column name="prix_unitaire" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="taux_tva" type="DECIMAL(5,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="montant_ht" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="montant_tva" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="montant_ttc" type="DECIMAL(15,2)" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="date_prestation" type="DATE"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="lignes_factures" baseTableSchemaName="finance"
            baseColumnNames="facture_id"
            referencedTableName="factures" referencedTableSchemaName="finance"
            referencedColumnNames="facture_id"
            constraintName="fk_lignes_factures_facture"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableName="lignes_factures" baseTableSchemaName="finance"
            baseColumnNames="produit_id"
            referencedTableName="produits" referencedTableSchemaName="inventory"
            referencedColumnNames="produit_id"
            constraintName="fk_lignes_factures_produit"/>

        <sql>
            ALTER TABLE finance.lignes_factures
            ADD CONSTRAINT chk_lignes_factures_quantite_positive CHECK (quantite &gt; 0)
        </sql>

        <sql>
            ALTER TABLE finance.lignes_factures
            ADD CONSTRAINT chk_lignes_factures_prix_positif CHECK (prix_unitaire &gt;= 0)
        </sql>

        <createIndex tableName="lignes_factures" schemaName="finance" indexName="ix_lignes_factures_facture">
            <column name="facture_id"/>
        </createIndex>

        <createIndex tableName="lignes_factures" schemaName="finance" indexName="ix_lignes_factures_nuitee">
            <column name="nuitee_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="lignes_factures" schemaName="finance"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 006-f.5 : table finance.paiements
         Encaissement (reception/encaissement par le client).
         ==================================================================== -->
    <changeSet id="006-f-5-create-table-paiements" author="cityprojects">
        <comment>
            Paiements recus. numero_paiement unique par hotel (UNIQUE (hotel_id,
            numero_paiement)) - genere par NumerotationService (PAY).
            mode_paiement enum cf. ModePaiement (ESPECES, CHEQUE, BANKILY, ...).
            Un paiement peut etre affecte a 1 ou plusieurs factures via
            affectations_paiements.
        </comment>

        <createTable tableName="paiements" schemaName="finance">
            <column name="paiement_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_paiements" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="numero_paiement" type="VARCHAR(40)">
                <constraints nullable="false"/>
            </column>
            <column name="compte_id" type="BIGINT"/>
            <column name="montant_total" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="devise" type="VARCHAR(3)" defaultValue="MRU">
                <constraints nullable="false"/>
            </column>
            <column name="mode_paiement" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="reference_paiement" type="VARCHAR(100)"/>
            <column name="date_paiement" type="DATE" defaultValueComputed="CURRENT_DATE">
                <constraints nullable="false"/>
            </column>
            <column name="statut" type="VARCHAR(20)" defaultValue="VALIDE">
                <constraints nullable="false"/>
            </column>
            <column name="commentaires" type="TEXT"/>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="VARCHAR(80)" defaultValue="system">
                <constraints nullable="false"/>
            </column>
            <column name="updated_by" type="VARCHAR(80)"/>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="paiements" baseTableSchemaName="finance"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_paiements_hotel"/>

        <addForeignKeyConstraint
            baseTableName="paiements" baseTableSchemaName="finance"
            baseColumnNames="compte_id"
            referencedTableName="comptes" referencedTableSchemaName="finance"
            referencedColumnNames="compte_id"
            constraintName="fk_paiements_compte"/>

        <addForeignKeyConstraint
            baseTableName="paiements" baseTableSchemaName="finance"
            baseColumnNames="user_id"
            referencedTableName="dbusers" referencedTableSchemaName="core"
            referencedColumnNames="user_id"
            constraintName="fk_paiements_user"/>

        <addUniqueConstraint
            tableName="paiements" schemaName="finance"
            columnNames="hotel_id, numero_paiement"
            constraintName="uk_paiements_hotel_numero"/>

        <sql>
            ALTER TABLE finance.paiements
            ADD CONSTRAINT chk_paiements_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <sql>
            ALTER TABLE finance.paiements
            ADD CONSTRAINT chk_paiements_montant_positive CHECK (montant_total &gt; 0)
        </sql>

        <createIndex tableName="paiements" schemaName="finance" indexName="ix_paiements_hotel_date">
            <column name="hotel_id"/>
            <column name="date_paiement"/>
        </createIndex>

        <createIndex tableName="paiements" schemaName="finance" indexName="ix_paiements_hotel_statut">
            <column name="hotel_id"/>
            <column name="statut"/>
        </createIndex>

        <rollback>
            <dropTable tableName="paiements" schemaName="finance"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 006-f.6 : table finance.affectations_paiements
         Pivot N..N entre paiements et factures (un paiement peut couvrir
         plusieurs factures, une facture peut etre payee en plusieurs versements).
         ==================================================================== -->
    <changeSet id="006-f-6-create-table-affectations-paiements" author="cityprojects">
        <comment>
            Pivot N..N paiements/factures. Pas de hotel_id : isolation portee
            par paiement_id (qui a hotel_id). Cle (paiement_id, facture_id) unique.
        </comment>

        <createTable tableName="affectations_paiements" schemaName="finance">
            <column name="affectation_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_affectations_paiements" nullable="false"/>
            </column>
            <column name="paiement_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="facture_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="montant_affecte" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="date_affectation" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="affectations_paiements" baseTableSchemaName="finance"
            baseColumnNames="paiement_id"
            referencedTableName="paiements" referencedTableSchemaName="finance"
            referencedColumnNames="paiement_id"
            constraintName="fk_affectations_paiement"
            onDelete="CASCADE"/>

        <addForeignKeyConstraint
            baseTableName="affectations_paiements" baseTableSchemaName="finance"
            baseColumnNames="facture_id"
            referencedTableName="factures" referencedTableSchemaName="finance"
            referencedColumnNames="facture_id"
            constraintName="fk_affectations_facture"/>

        <addUniqueConstraint
            tableName="affectations_paiements" schemaName="finance"
            columnNames="paiement_id, facture_id"
            constraintName="uk_affectations_paiement_facture"/>

        <sql>
            ALTER TABLE finance.affectations_paiements
            ADD CONSTRAINT chk_affectations_montant_positive CHECK (montant_affecte &gt; 0)
        </sql>

        <createIndex tableName="affectations_paiements" schemaName="finance" indexName="ix_affectations_facture">
            <column name="facture_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="affectations_paiements" schemaName="finance"/>
        </rollback>
    </changeSet>

    <!-- ====================================================================
         Changeset 006-f.7 : table finance.operations_comptes
         Journal d'audit des ecritures debit/credit par compte.
         ==================================================================== -->
    <changeSet id="006-f-7-create-table-operations-comptes" author="cityprojects">
        <comment>
            Journal des operations comptables (audit trail). Une ligne creee a
            chaque facturation (debit) ou paiement (credit). solde_avant et
            solde_apres permettent de verifier la coherence chronologique.
        </comment>

        <createTable tableName="operations_comptes" schemaName="finance">
            <column name="operation_id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="pk_operations_comptes" nullable="false"/>
            </column>
            <column name="hotel_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="compte_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="type_operation" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="montant" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="libelle" type="VARCHAR(500)">
                <constraints nullable="false"/>
            </column>
            <column name="facture_id" type="BIGINT"/>
            <column name="paiement_id" type="BIGINT"/>
            <column name="solde_avant" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="solde_apres" type="DECIMAL(15,2)">
                <constraints nullable="false"/>
            </column>
            <column name="date_operation" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="operations_comptes" baseTableSchemaName="finance"
            baseColumnNames="hotel_id"
            referencedTableName="hotels" referencedTableSchemaName="core"
            referencedColumnNames="hotel_id"
            constraintName="fk_operations_hotel"/>

        <addForeignKeyConstraint
            baseTableName="operations_comptes" baseTableSchemaName="finance"
            baseColumnNames="compte_id"
            referencedTableName="comptes" referencedTableSchemaName="finance"
            referencedColumnNames="compte_id"
            constraintName="fk_operations_compte"/>

        <addForeignKeyConstraint
            baseTableName="operations_comptes" baseTableSchemaName="finance"
            baseColumnNames="facture_id"
            referencedTableName="factures" referencedTableSchemaName="finance"
            referencedColumnNames="facture_id"
            constraintName="fk_operations_facture"/>

        <addForeignKeyConstraint
            baseTableName="operations_comptes" baseTableSchemaName="finance"
            baseColumnNames="paiement_id"
            referencedTableName="paiements" referencedTableSchemaName="finance"
            referencedColumnNames="paiement_id"
            constraintName="fk_operations_paiement"/>

        <addForeignKeyConstraint
            baseTableName="operations_comptes" baseTableSchemaName="finance"
            baseColumnNames="user_id"
            referencedTableName="dbusers" referencedTableSchemaName="core"
            referencedColumnNames="user_id"
            constraintName="fk_operations_user"/>

        <sql>
            ALTER TABLE finance.operations_comptes
            ADD CONSTRAINT chk_operations_hotel_id_positive CHECK (hotel_id &gt; 0)
        </sql>

        <sql>
            ALTER TABLE finance.operations_comptes
            ADD CONSTRAINT chk_operations_montant_positive CHECK (montant &gt; 0)
        </sql>

        <createIndex tableName="operations_comptes" schemaName="finance" indexName="ix_operations_hotel_compte">
            <column name="hotel_id"/>
            <column name="compte_id"/>
        </createIndex>

        <createIndex tableName="operations_comptes" schemaName="finance" indexName="ix_operations_hotel_date">
            <column name="hotel_id"/>
            <column name="date_operation"/>
        </createIndex>

        <rollback>
            <dropTable tableName="operations_comptes" schemaName="finance"/>
        </rollback>
    </changeSet>

